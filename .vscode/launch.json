    {
        // 使用 IntelliSense 了解相关属性。 
        // 悬停以查看现有属性的描述。
        "version": "0.2.0",
        "configurations": [
            // ---------------------------------------------------------
            // 1. 新增：Cortex-Debug 极速纯净烧录专用配置 
            // ---------------------------------------------------------
            {
                "name": "Cortex-Debug: 极速裸烧 (Flash)",
                "type": "cortex-debug",
                "request": "launch",
                "servertype": "openocd",
                "cwd": "${workspaceFolder}",
                "executable": "${workspaceFolder}/build/Debug/pre10-patient-stm32-v1.0.0.elf",
                "configFiles": [
                    "interface/stlink.cfg",
                    "target/stm32h7x.cfg" // 注意：如果是 F4 或其他型号，请把 h7x 改成对应型号，如 stm32f4x.cfg
                ],
                "runToEntryPoint": "main",
                "showDevDebugOutput": "none"
            },
            // ---------------------------------------------------------
            // 2. 原有：ST官方插件生成的调试配置 (保留不变，防备用)
            // ---------------------------------------------------------
            {
                "type": "stlinkgdbtarget",
                "request": "launch",
                "name": "STM32Cube: Launch ST-Link GDB Server",
                "origin": "snippet",
                "cwd": "${workspaceFolder}",
                "preBuild": "${command:st-stm32-ide-debug-launch.build}",
                "runEntry": "main",
                "imagesAndSymbols": [
                    {
                        "imageFileName": "${command:st-stm32-ide-debug-launch.get-projects-binary-from-context1}"
                    }
                ]
            },
            {
                "name": "11",
                "type": "stlinkgdbtarget",
                "request": "launch",
                "cwd": "${workspaceFolder}",
                "preBuild": "${command:st-stm32-ide-debug-launch.build}",
                "runEntry": "main",
                "imagesAndSymbols": [
                    {
                        "imageFileName": "${workspaceFolder}/build/Debug/pre10-patient-stm32-v1.0.0.elf"
                    }
                ],
                "verbose": false
            }
        ]
    }














